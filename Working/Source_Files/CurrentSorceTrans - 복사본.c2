				// Y = (Yn-Y0)*(X-X0)/(Xn-X0) + Y0
				// Xn=Ūź └Ū ├ų┤ļ░¬, X0=Ūź└Ū ├ų╝ę░¬ 
				// Yn=ŠŲ│¬Ę╬▒ū ╗§Ę╬┐Ņ ╝│┴ż░¬ ├ų┤ļ░¬,  Y0 = ├ų╝ę░¬
				// X ┤┬ └╠└³░¬, Y = ║Ė┴żŪčüŻ
//				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)*(trans_anlog_pwmVaule-DAC_4_20MA[0])/(DAC_4_20MA[32]-DAC_4_20MA[0]) + configData.outputConfig.outputReal4mA;

//				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)
//				*(ppm_4_20ma/100-4) / (16) + configData.outputConfig.outputReal4mA;

				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)
				*(ppm_4_20ma-1159) / (5937-1159) + configData.outputConfig.outputReal4mA;


				currentData.S1mA = (uint32_t)(((Current1Slope * (float)trans_anlog_pwmVaule)+Current11Offset)*100);
			}

			else if(currentData.Device_Selector_Mode&SENSOR_2_MODE)	{
				//trans_anlog_pwmVaule = DAC_4_20MA[currentData.S2PPM/50]; // 200░│└ŽČ¦
//				trans_anlog_pwmVaule = TABLE_4_20MA2[currentData.S2PPM/10];	// 1000░│└ŽČ¦ (0~10000)
//				if (currentData.S2PPM>900) trans_anlog_pwmVaule+=40;
//				if (currentData.S2PPM>6000 && currentData.S2PPM<8100) trans_anlog_pwmVaule-=10;

				f1 = currentData.S2PPM/1000.0;	// ┐╣ 5000 =5.000
//				f2 = 1.6024*f1 + 3.976;	 	 // y=1.6024*x+3.976
				f2 = 1.6*f1 + 4.0;	 	 // y=1.6024*x+3.976
//				ppm_4_20ma = f2*1000;
//				ppm_4_20ma = 315.94*f2 - 123.75;
//				ppm_4_20ma = 302.21*f2 - 72.075;
//				ppm_4_20ma = 302.08*f2 - 81.667;
				ppm_4_20ma = 298.62*f2 - 34.747;


/*
  				if ( ppm_4_20ma <= TABLE_4_20MA_100[0]) {
					trans_anlog_pwmVaule = DAC_4_20MA[0];
				}
  				else if ( ppm_4_20ma >= TABLE_4_20MA_100[32]) {
					trans_anlog_pwmVaule = DAC_4_20MA[32];
				}	
				else { 
					for (i=1;i<33;i++) {
						if ( ppm_4_20ma == TABLE_4_20MA_100[i]) {
							trans_anlog_pwmVaule = DAC_4_20MA[i];
							break;
						}
						else if ( ppm_4_20ma < TABLE_4_20MA_100[i]) {
							j = TABLE_4_20MA_100[i] - TABLE_4_20MA_100[i-1];
							k = ppm_4_20ma - TABLE_4_20MA_100[i-1];
							l = k*100/j;

							j = DAC_4_20MA[i] - DAC_4_20MA[i-1];
							k = j * l /100;

						trans_anlog_pwmVaule = (DAC_4_20MA[i] + k); // /10;	// /10 └║ └▄Ę∙┐░╝ęČ¾╝Ł 

							break;
						}
					}
				}
*/
  				//ppm_4_20ma /=10;	// ░Ķ╗Ļ ŲĒĖ«ŪŽ░į ŪŽ▒Ō└¦ŪŽ┐® 

				// DAC ░¬ ║Ė┴żŪŽ▒Ō, Ūź░Ī ▒Ō┴ž└╬Ąź ŠŲ│»Ę╬▒ū░¬└╗ ╝÷┴żŪč░═└╗ ░Ī┴÷░Ē Ū÷└ń DAC ░¬└╗ ║Ė┴żŪč┤┘.
				// Y = (Yn-Y0)*(X-X0)/(Xn-X0) + Y0
				// Xn=Ūź └Ū ├ų┤ļ░¬, X0=Ūź└Ū ├ų╝ę░¬ 
				// Yn=ŠŲ│¬Ę╬▒ū ╗§Ę╬┐Ņ ╝│┴ż░¬ ├ų┤ļ░¬,  Y0 = ├ų╝ę░¬
				// X ┤┬ └╠└³░¬, Y = ║Ė┴żŪčüŻ
//				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)*(trans_anlog_pwmVaule-DAC_4_20MA[0])/(DAC_4_20MA[32]-DAC_4_20MA[0]) + configData.outputConfig.outputReal4mA;


				// (d-b)/(c-a)*(x-a) + b,
				// a=4ma, b=4ma ┐Ī╝Ł└Ū ╝│┴ż░¬(pwm), c=20ma, d=20ma └ŽČ¦└Ū ╝│┴ż░¬(pwm) 
				// x=└įĘ┬░¬(4-20ma ║»╚»Ą╚░¬), y=pwm
//				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)
//				*(ppm_4_20ma/100-4) / (16) + configData.outputConfig.outputReal4mA;

//				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)
//				*(ppm_4_20ma/100-1108) / (5943-1108) + configData.outputConfig.outputReal4mA;

				trans_anlog_pwmVaule = (configData.outputConfig.outputReal20mA - configData.outputConfig.outputReal4mA)
				*(ppm_4_20ma-1159) / (5937-1159) + configData.outputConfig.outputReal4mA;


				currentData.S1mA = (uint32_t)(((Current1Slope * (float)trans_anlog_pwmVaule)+Current11Offset)*100);
			}


			// DAC1 output
			TIM8_Chage_Duty_Channel(2,trans_anlog_pwmVaule);
			#ifdef NEW_BOARD
//			DAC_output(1, trans_anlog_pwmVaule);
			#endif
			
			if(currentData.temperature != 0)
			{
				Temperture_Slop_Cal(0,0);
				trans_temp_pwmVaule = (uint16_t)((Temp_Slope*((float)currentData.temperature * 0.01))+Temp_Offset); 

				// DAC2 output
				TIM8_Chage_Duty_Channel(3,trans_temp_pwmVaule);
				#ifdef NEW_BOARD
				DAC_output(2, trans_temp_pwmVaule);
				#endif
			}
		}
	}
	else {
		TIM8_Chage_Duty_Channel(2,0);
		TIM8_Chage_Duty_Channel(3,0);
	}
}

	   
void TIM8_Chage_Duty_Channel(uint16_t channel , uint16_t Duty)
{ 
	 
		switch (channel)
  	 {
        case 1 :
					      TIM8->CCR1 = Duty;  
				      break;
				case 2 :
					      TIM8->CCR2 = Duty;   
					    break;
				case 3 :
					      TIM8->CCR3 = Duty;   
					    break;
				case 4 :
					      TIM8->CCR4 = Duty;
					    break;
				default:
					    break;				
     }
}
