{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32: Debug (ST-LINK V2)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/ID_Solution.elf",
      "device": "STM32F103VE",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f1x.cfg"
      ],
      "preLaunchTask": "STM32: Build",
      "runToEntryPoint": "main"
    },
    {
      "name": "STM32: Flash & Run",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/ID_Solution.elf",
      "device": "STM32F103VE",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f1x.cfg"
      ],
      "preLaunchTask": "STM32: Build",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw"
    }
  ]
}
