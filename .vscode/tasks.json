{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "STM32: Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-G", "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/arm-none-eabi.cmake",
        "-B", "${workspaceFolder}/build",
        "-S", "${workspaceFolder}"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "STM32: Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "${workspaceFolder}/build",
        "--", "-j"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "STM32: Flash (st-flash)",
      "type": "shell",
      "command": "st-flash",
      "args": [
        "write",
        "${workspaceFolder}/build/ID_Solution.bin",
        "0x08000000"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "dependsOn": "STM32: Build",
      "problemMatcher": []
    }
  ]
}
